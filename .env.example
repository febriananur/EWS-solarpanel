# Firebase Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Server
PORT=3000

# Thresholds untuk panel surya
TEMP_WARNING=55        # °C - mulai waspada
TEMP_DANGER=70         # °C - bahaya tinggi
HUMIDITY_MIN=10        # % - kelembaban terlalu rendah (kering = rawan api)
PREDICTION_MINUTES=10  # Prediksi berapa menit ke depan

# ── Telegram Bot ────────────────────────────────────────────────────────────────
# Cara setup:
#   1. Buka Telegram, cari @BotFather → /newbot → ikuti instruksi
#   2. Copy token yang diberikan ke TELEGRAM_BOT_TOKEN
#   3. Untuk TELEGRAM_CHAT_ID:
#      - Personal : kirim pesan ke bot, lalu buka https://api.telegram.org/bot<TOKEN>/getUpdates
#      - Grup     : tambah bot ke grup, kirim pesan, lihat chat.id di getUpdates (biasanya negatif)
#      - Multiple : pisah dengan koma, contoh: 123456789,-987654321
#
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=123456789

# Rate limit bisa dikustomisasi di src/telegramService.js (RATE_LIMITS)
# Default: WARNING=30mnt, DANGER=15mnt, CRITICAL=5mnt
